{
  "expo": {
    "name": "Mockly",
    "slug": "mockly",
    "version": "1.0.0",
    "scheme": "mockly",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mockly.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B448B",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.mockly.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1B448B"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
